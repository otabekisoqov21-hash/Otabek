    def load(self):

        if os.path.exists(DATA):

            with open(DATA,"r",encoding="utf8") as f:

                return json.load(f)

        return {

            "chat":[],

            "notes":[],

            "tasks":[]

        }

    def save(self):

        with open(DATA,"w",encoding="utf8") as f:

            json.dump(self.data,f,indent=4,ensure_ascii=False)

    def speak(self,text):

        print("JARVIS >",text)

        engine.say(text)

        engine.runAndWait()

    def listen(self):

        r=sr.Recognizer()

        with sr.Microphone() as mic:

            print("Gapiring...")

            audio=r.listen(mic)

        try:

            text=r.recognize_google(audio,language="uz-UZ")

            print("Siz >",text)

            return text.lower()

        except:

            return ""

