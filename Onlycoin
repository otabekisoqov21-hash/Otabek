from aiogram import Router, F
from aiogram.types import Message
from database import sql, db

router = Router()

@router.message(F.text == "🦁 Coin Bosish")
async def coin(message: Message):

    user_id = message.from_user.id

    sql.execute("SELECT coins, energy, boost FROM users WHERE user_id=?", (user_id,))
    data = sql.fetchone()

    coins, energy, boost = data

    if energy <= 0:
        await message.answer("❌ Energy tugagan")
        return

    coins += boost
    energy -= 1

    sql.execute("UPDATE users SET coins=?, energy=? WHERE user_id=?",
                (coins, energy, user_id))
    db.commit()

    await message.answer(f"+{boost} coin\n💰 {coins}\n⚡ {energy}")
