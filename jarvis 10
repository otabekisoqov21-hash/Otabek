def banner_korsatish():
    """Dastur ishga tushganda ekranga chiqadigan boshlang'ich
    ma'lumotlarni va halol ogohlantirishlarni ko'rsatadi."""
    print("=" * 64)
    print(f"   {ASSISTANT_NAME} — o'zbek tilida ishlaydigan virtual yordamchi")
    print("=" * 64)

    if not GTTS_BOR:
        print("[Eslatma] 'gTTS' kutubxonasi topilmadi — ovoz chiqmaydi, faqat matn.")
        print("          O'rnatish uchun: pip install gTTS")
    elif OVOZ_TILI != "uz":
        print("[Eslatma] Google'ning ovoz xizmati hozircha o'zbek tilini to'liq "
              f"qo'llamayapti, shu sababli ovoz '{ZAXIRA_TIL}' tilida eshittiriladi, "
              "lekin barcha matnlar va buyruqlar 100% o'zbek tilida.")

    if not OVOZ_TANISH_BOR:
        print("[Eslatma] 'SpeechRecognition' kutubxonasi topilmadi.")
        print("          O'rnatish uchun: pip install SpeechRecognition pyaudio")
    print()


def ovoz_rejimi():
    """Mikrofon orqali doimiy tinglab turadigan rejim."""
    gapir(f"Salom, men {ASSISTANT_NAME}. Sizni tinglayapman.")
    while True:
        buyruq = eshit()
        if buyruq is None:
            gapir("Mikrofon topilmadi. Matn rejimiga o'tyapman.")
            matn_rejimi()
            return
        davom_etsinmi = buyruqni_bajar(buyruq)
        if not davom_etsinmi:
            break


def matn_rejimi():
    """Mikrofon yo'q yoki ishlamagan hollarda yozib buyruq berish
    rejimi."""
    gapir("Matn rejimida ishlayapman. Buyruqni yozib, Enter bosing.")
    print("(Masalan: 'salom', 'ob havoni qidir', 'papkani och', 'yordam', 'xayr')\n")
    while True:
        try:
            buyruq = input("Siz: ").strip()
        except (EOFError, KeyboardInterrupt):
            print()
            gapir("Xayr!")
            break
        davom_etsinmi = buyruqni_bajar(buyruq)
        if not davom_etsinmi:
            break


def asosiy():
    """Dasturning bosh funksiyasi: papkalarni tayyorlaydi, banner
    ko'rsatadi va ovozli yoki matnli rejimni tanlab ishga tushiradi."""
    papkalarni_tayyorlash()
    log_yozish("Dastur ishga tushdi.")
    banner_korsatish()

    if not OVOZ_TANISH_BOR:
        matn_rejimi()
        return

    try:
        ovoz_rejimi()
    except Exception as e:
        print(f"[Ovozli rejimda xato: {e}]")
        matn_rejimi()


if __name__ == "__main__":
    asosiy()

