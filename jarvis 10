ZAXIRA_TIL = "ru"


def papkalarni_tayyorlash():
    """Dastur ishlashi uchun zarur bo'lgan papkalarni yaratadi (mavjud
    bo'lsa, hech narsa qilmaydi)."""
    for papka in (ASOSIY_PAPKA, YUKLAMALAR_PAPKA):
        os.makedirs(papka, exist_ok=True)


def vaqt_belgisi():
    """Joriy vaqtni 'YYYY-MM-DD HH:MM:SS' formatida qaytaradi."""
    return time.strftime("%Y-%m-%d %H:%M:%S")


def log_yozish(xabar):
    """Dastur faoliyatini log fayliga yozadi. Xato yuz bersa ham dastur
    to'xtamasligi uchun xatolik jim yutiladi."""
    try:
        papkalarni_tayyorlash()
        with open(LOG_FAYLI, "a", encoding="utf-8") as f:
            f.write(f"[{vaqt_belgisi()}] {xabar}\n")
    except Exception:
        pass


def faylga_qator_qoshish(yol, qator):
    """Berilgan matn fayliga yangi qator qo'shadi (fayl bo'lmasa, uni
    yaratadi)."""
    papkalarni_tayyorlash()
    with open(yol, "a", encoding="utf-8") as f:
        f.write(qator.rstrip("\n") + "\n")


def fayldan_qatorlarni_oqish(yol):
    """Berilgan fayldagi barcha qatorlarni (bo'sh qatorlarsiz) ro'yxat
    qilib qaytaradi. Fayl mavjud bo'lmasa, bo'sh ro'yxat qaytaradi."""
    if not os.path.exists(yol):
        return []
    with open(yol, "r", encoding="utf-8") as f:
        return [q.rstrip("\n") for q in f.readlines() if q.strip()]


def faylga_qatorlarni_yozish(yol, qatorlar):
    """Berilgan ro'yxatni faylga qayta yozadi — fayldagi eski mazmunni
    to'liq almashtiradi."""
    papkalarni_tayyorlash()
    with open(yol, "w", encoding="utf-8") as f:
        for q in qatorlar:
            f.write(q.rstrip("\n") + "\n")


