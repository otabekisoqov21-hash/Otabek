_OVOZ_YOQILGAN = True


def ovoz_uz_qollanadimi():
    """Google TTS xizmati 'uz' (o'zbek) tilini qo'llab-quvvatlaydimi,
    tekshiradi. Internet bo'lmasa ham dastur yiqilib qolmasligi uchun
    xatolikni ushlab, True qaytaradi (keyin gapir() ichida qayta
    tekshiriladi)."""
    if not GTTS_BOR:
        return False
    try:
        return "uz" in tts_langs()
    except Exception:
        return True


OVOZ_TILI = "uz" if ovoz_uz_qollanadimi() else ZAXIRA_TIL


def audio_fayl_ochish(yol):
    """playsound o'rnatilmagan bo'lsa, operatsion tizimning standart
    pleyeri orqali audio faylni ochadi."""
    system = platform.system()
    try:
        if system == "Windows":
            os.startfile(yol)  # noqa
        elif system == "Darwin":
            subprocess.run(["afplay", yol], check=False)
        else:
            subprocess.run(["xdg-open", yol], check=False)
    except Exception as e:
        print(f"[Audio ochilmadi: {e}]")


def ovozni_ochirish():
    """Ovozli javoblarni vaqtincha o'chiradi — endi faqat matn chiqadi."""
    global _OVOZ_YOQILGAN
    _OVOZ_YOQILGAN = False
    print(f"{ASSISTANT_NAME}: Ovoz o'chirildi, endi faqat matn bilan javob beraman.")


def ovozni_yoqish():
    """Ovozli javob berishni qayta yoqadi."""
    global _OVOZ_YOQILGAN
    _OVOZ_YOQILGAN = True
    print(f"{ASSISTANT_NAME}: Ovoz qayta yoqildi.")


def gapir(matn):
    """Berilgan matnni ekranga chiqaradi va (agar ovoz yoqilgan va gTTS
    mavjud bo'lsa) ovoz bilan aytadi. Ovoz tizimida xatolik bo'lsa ham
    dastur ishlashda davom etadi — faqat matn ko'rinadi."""
    print(f"\n{ASSISTANT_NAME}: {matn}")
    log_yozish(f"GAPIRDI: {matn}")

    if not GTTS_BOR or not _OVOZ_YOQILGAN:
        return

    try:
        tts = gTTS(text=matn, lang=OVOZ_TILI)
        with tempfile.NamedTemporaryFile(delete=False, suffix=".mp3") as fp:
            vaqtinchalik_yol = fp.name
        tts.save(vaqtinchalik_yol)

        if PLAYSOUND_BOR:
            playsound(vaqtinchalik_yol)
        else:
            audio_fayl_ochish(vaqtinchalik_yol)
            time.sleep(min(len(matn) * 0.06, 6))

        try:
            os.remove(vaqtinchalik_yol)
        except OSError:
            pass
    except Exception as e:
        print(f"[Ovoz xatosi (internet yo'qmi?): {e}]")


def eshit(vaqt_limiti=6):
    """Mikrofondan ovozli buyruqni tinglab, uni o'zbekcha matnga
    aylantiradi. Mikrofon topilmasa None, hech narsa eshitilmasa yoki
    tushunilmasa bo'sh satr qaytaradi."""
    if not OVOZ_TANISH_BOR:
        return None

    recognizer = sr.Recognizer()
    try:
        with sr.Microphone() as source:
            print("[Tinglanyapti...]")
            recognizer.adjust_for_ambient_noise(source, duration=0.5)
            audio = recognizer.listen(source, timeout=vaqt_limiti, phrase_time_limit=8)
    except sr.WaitTimeoutError:
        return ""
    except OSError:
        return None

    try:
        matn = recognizer.recognize_google(audio, language="uz-UZ")
        print(f"Siz: {matn}")
        log_yozish(f"ESHITDI: {matn}")
        return matn.lower()
    except sr.UnknownValueError:
        return ""
    except sr.RequestError:
        gapir("Internetga ulanishda muammo bor, ovozni tanib bo'lmadi.")
        return ""


