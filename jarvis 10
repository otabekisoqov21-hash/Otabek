def dasturni_yopish(nomi):
    """Berilgan nom bo'yicha ishlayotgan jarayonni (processni)
    to'xtatadi."""
    if not PSUTIL_BOR:
        gapir("Bu funksiya uchun 'psutil' kutubxonasi kerak (pip install psutil).")
        return False
    nomi = (nomi or "").strip().lower()
    topildi = False
    for jarayon in psutil.process_iter(["pid", "name"]):
        if nomi and nomi in (jarayon.info["name"] or "").lower():
            try:
                jarayon.terminate()
                topildi = True
            except Exception:
                pass
    gapir(f"\"{nomi}\" dasturi yopildi." if topildi else f"\"{nomi}\" nomli ishlayotgan dastur topilmadi.")
    return topildi


