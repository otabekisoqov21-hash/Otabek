    gapir(f"Hozir {FASLLAR[oy]} fasli")
    return FASLLAR[oy]


def kungacha_qolgan_kunlar(maqsad_sana_str):
    """'YYYY-MM-DD' formatidagi sanagacha necha kun qolganini
    hisoblaydi va aytadi."""
    try:
        maqsad = datetime.datetime.strptime(maqsad_sana_str.strip(), "%Y-%m-%d").date()
    except ValueError:
        gapir("Sanani 'YYYY-MM-DD' formatida kiriting, masalan: 2026-09-01")
        return None
    qolgan = (maqsad - datetime.date.today()).days
    if qolgan > 0:
        gapir(f"{maqsad_sana_str} sanasigacha {qolgan} kun qoldi")
    elif qolgan == 0:
        gapir("Bu — bugungi sana!")
    else:
        gapir(f"Bu sana {abs(qolgan)} kun oldin o'tib ketgan")
    return qolgan


def yoshni_hisoblash(tugilgan_sana_str):
    """'YYYY-MM-DD' formatidagi tug'ilgan sanaga ko'ra hozirgi yoshni
    hisoblab, aytadi."""
    try:
        tugilgan = datetime.datetime.strptime(tugilgan_sana_str.strip(), "%Y-%m-%d").date()
    except ValueError:
        gapir("Sanani 'YYYY-MM-DD' formatida kiriting, masalan: 2000-05-20")
        return None
    bugun = datetime.date.today()
    yosh = bugun.year - tugilgan.year - (
        (bugun.month, bugun.day) < (tugilgan.month, tugilgan.day)
    )
    gapir(f"Siz {yosh} yoshdasiz")
    return yosh


