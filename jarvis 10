def _ochish(yol):
    """Berilgan fayl/papkani operatsion tizimning standart vositasi
    bilan ochadigan ichki yordamchi funksiya."""
    system = platform.system()
    if system == "Windows":
        os.startfile(yol)  # noqa
    elif system == "Darwin":
        subprocess.run(["open", yol], check=False)
    else:
        subprocess.run(["xdg-open", yol], check=False)


def fayl_yuklash(url, fayl_nomi=None):
    """Internetdagi to'g'ridan-to'g'ri (direct) link orqali faylni
    yuklab, Yuklamalar papkasiga saqlaydi."""
    papkalarni_tayyorlash()
    try:
        gapir("Fayl yuklanyapti, biroz kuting.")
        javob = requests.get(url, stream=True, timeout=30,
                              headers={"User-Agent": "Mozilla/5.0"})
        javob.raise_for_status()
        if not fayl_nomi:
            fayl_nomi = url.split("?")[0].rstrip("/").split("/")[-1] or "yuklangan_fayl"
        toliq_yol = os.path.join(YUKLAMALAR_PAPKA, fayl_nomi)
        with open(toliq_yol, "wb") as f:
            for qism in javob.iter_content(chunk_size=8192):
                if qism:
                    f.write(qism)
        gapir(f"Fayl muvaffaqiyatli yuklandi: {fayl_nomi}")
        return toliq_yol
    except Exception as e:
        gapir("Faylni yuklashda xatolik yuz berdi.")
        print(f"[Xato: {e}]")
        return None


def papkani_ochish(yol=None):
    """Berilgan papkani (yoki standart Yuklamalar papkasini) ochadi."""
    yol = yol or YUKLAMALAR_PAPKA
    if not os.path.isdir(yol):
        gapir("Bunday papka topilmadi.")
        return False
    try:
        _ochish(yol)
        gapir("Papka ochildi.")
        return True
    except Exception as e:
        gapir(f"Papkani ochib bo'lmadi: {e}")
        return False


def yuklamalar_papkasini_ochish():
    """Jarvis'ning Yuklamalar papkasini ochadi (yo'q bo'lsa, yaratadi)."""
    papkalarni_tayyorlash()
    return papkani_ochish(YUKLAMALAR_PAPKA)


