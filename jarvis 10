def wikipedia_qidiruv(soz):
    """O'zbekcha Vikipediyadan berilgan mavzu bo'yicha qisqacha
    ma'lumot olib, aytib beradi."""
    soz = (soz or "").strip()
    if not soz:
        gapir("Qaysi mavzuni qidirishni aytmadingiz.")
        return
    try:
        url = "https://uz.wikipedia.org/w/api.php"
        parametrlar = {
            "action": "query", "format": "json", "prop": "extracts",
            "exintro": True, "explaintext": True, "redirects": 1,
            "titles": soz,
        }
        javob = requests.get(url, params=parametrlar, timeout=10)
        sahifalar = javob.json().get("query", {}).get("pages", {})
        for sahifa in sahifalar.values():
            matn = sahifa.get("extract", "").strip()
            if matn:
                gapir(matn[:500])
                return matn
        gapir("Afsuski, bu mavzu bo'yicha Vikipediyada ma'lumot topilmadi.")
    except Exception as e:
        gapir("Vikipediyaga ulanishda xatolik yuz berdi.")
        print(f"[Xato: {e}]")
    return None


