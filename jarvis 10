def buyruqni_bajar(matn):
    """Foydalanuvchi buyrug'ini tahlil qilib, mos handlerni chaqiradi.
    Dasturni davom ettirish kerak bo'lsa True, to'xtatish kerak bo'lsa
    False qaytaradi."""
    if matn is None:
        return True
    matn = matn.strip().lower()
    if not matn:
        return True

    for kalit_sozlar, handler in BUYRUQLAR_ROYXATI:
        if any(kalit in matn for kalit in kalit_sozlar):
            natija = handler(matn)
            return natija if natija is not None else True

    gapir("Kechirasiz, bu buyruqni tushunmadim. 'Yordam' deb ayting, men nima qila olishimni aytib beraman.")
    return True


