def obhavo_korsatish(shahar):
    """wttr.in xizmati orqali berilgan shahar ob-havosini aytadi."""
    shahar = (shahar or "").strip() or "Tashkent"
    try:
        url = f"https://wttr.in/{quote(shahar)}?format=j1"
        javob = requests.get(url, timeout=10)
        malumot = javob.json()
        joriy = malumot["current_condition"][0]
        harorat = joriy["temp_C"]
        holat = joriy.get("weatherDesc", [{"value": ""}])[0]["value"]
        gapir(f"{shahar} shahrida hozir harorat {harorat} gradus, holat: {holat}")
        return harorat
    except Exception as e:
        gapir("Ob-havo ma'lumotini olib bo'lmadi, internetni tekshiring.")
        print(f"[Xato: {e}]")
        return None


def valyuta_kursi(dan, ga="UZS", miqdor=1):
    """Ikki valyuta orasidagi kursni ko'rsatadi (masalan USD -> UZS)."""
    dan, ga = dan.strip().upper(), ga.strip().upper()
    try:
        url = f"https://api.exchangerate-api.com/v4/latest/{dan}"
        javob = requests.get(url, timeout=10)
        kurslar = javob.json().get("rates", {})
        if ga not in kurslar:
            gapir(f"{ga} valyutasi topilmadi.")
            return None
        natija = kurslar[ga] * miqdor
        gapir(f"{miqdor} {dan} = {natija:,.2f} {ga}")
        return natija
    except Exception as e:
        gapir("Valyuta kursini olib bo'lmadi, internetni tekshiring.")
        print(f"[Xato: {e}]")
        return None


