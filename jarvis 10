def parametrni_olish(matn, olib_tashlanadigan_sozlar):
    """Matndan berilgan kalit so'z/iboralarni olib tashlab, qolgan
    qismini (taxminiy parametrni) qaytaradi."""
    natija = matn
    for soz in olib_tashlanadigan_sozlar:
        natija = natija.replace(soz, "")
    return natija.strip(" :,.-")


def raqamni_topish(matn):
    """Matn ichidan birinchi butun sonni topib qaytaradi (topilmasa
    None)."""
    mos = re.search(r"-?\d+", matn)
    return int(mos.group()) if mos else None


def sanani_topish(matn):
    """Matn ichidan 'YYYY-MM-DD' formatidagi sanani topib qaytaradi."""
    mos = re.search(r"\d{4}-\d{2}-\d{2}", matn)
    return mos.group() if mos else None


def sonni_topish(matn):
    """Matn ichidan birinchi o'nlik/butun sonni (float sifatida) topib
    qaytaradi (topilmasa None)."""
    mos = re.search(r"-?\d+(?:\.\d+)?", matn)
    return float(mos.group()) if mos else None


def matematik_ifodani_topish(matn):
    """Matn ichidan faqat raqam va matematik amal belgilaridan iborat
    bo'lgan eng uzun bo'lakni topib qaytaradi (atrofidagi o'zbekcha
    so'zlarni e'tiborsiz qoldiradi)."""
    mos = re.search(r"\d[\d\.\+\-\*\/\(\)\s%]*[\d\)]|\d", matn)
    return mos.group().strip() if mos else ""


