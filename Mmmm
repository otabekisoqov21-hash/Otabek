def load_plugins(self):

    self.plugins = {}

    plugin_folder = os.path.join(self.workspace, "plugins")

    os.makedirs(plugin_folder, exist_ok=True)

    for file in os.listdir(plugin_folder):

        if file.endswith(".py"):

            try:
                path = os.path.join(plugin_folder, file)

                with open(path, "r", encoding="utf-8") as f:
                    code = f.read()

                local_vars = {}

                exec(code, {}, local_vars)

                self.plugins[file] = local_vars

                self.speak(f"{file} plugin yuklandi.")

            except Exception as e:
                print("Plugin xato:", file, e)


def run_plugin(self, name, function, *args):

    try:

        plugin = self.plugins.get(name)

        if not plugin:
            self.speak("Plugin topilmadi.")
            return

        func = plugin.get(function)

        if not func:
            self.speak("Funksiya topilmadi.")
            return

        return func(*args)

    except Exception as e:
        print(e)
        self.speak("Plugin ishlamadi.")


def create_plugin(self, name):

    plugin_path = os.path.join(
        self.workspace,
        "plugins",
        name + ".py"
    )

    os.makedirs(os.path.dirname(plugin_path), exist_ok=True)

    code = f"""
def run():
    print("{name} plugin ishladi")

def info():
    return "Plugin: {name}"
"""

    with open(plugin_path, "w", encoding="utf-8") as f:
        f.write(code)

    self.speak("Plugin yaratildi.")


def list_plugins(self):

    plugin_folder = os.path.join(self.workspace, "plugins")

    if not os.path.exists(plugin_folder):

        self.speak("Plugin yo'q.")

        return

    files = os.listdir(plugin_folder)

    print("\n===== PLUGINS =====")

    for f in files:

        print("-", f)


def delete_plugin(self, name):

    path = os.path.join(
        self.workspace,
        "plugins",
        name
    )

    if os.path.exists(path):

        os.remove(path)

        self.speak("Plugin o'chirildi.")

    else:

        self.speak("Topilmadi.")


def reload_plugins(self):

    self.speak("Pluginlar yangilanmoqda...")

    self.load_plugins()
