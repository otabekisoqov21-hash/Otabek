def execute_command(self, cmd):

    cmd = cmd.lower().strip()

    if not cmd:
        return

    self.log("CMD: " + cmd)

    # ======================
    # SYSTEM BUYRUQLAR
    # ======================
    if cmd == "system":
        self.system_info()

    elif cmd == "battery":
        self.battery_info()

    elif cmd == "internet":
        self.internet_test()

    # ======================
    # FILE BUYRUQLAR
    # ======================
    elif cmd.startswith("mkdir "):
        self.create_folder(cmd[6:])

    elif cmd.startswith("touch "):
        self.create_file(cmd[6:])

    elif cmd.startswith("read "):
        self.read_file(cmd[5:])

    elif cmd.startswith("del "):
        self.delete_item(cmd[4:])

    elif cmd.startswith("rename "):
        parts = cmd.split(" ")
        if len(parts) >= 3:
            self.rename_item(parts[1], parts[2])

    elif cmd == "files":
        self.list_files()

    elif cmd == "workspace":
        self.open_workspace()

    # ======================
    # PYTHON BUYRUQLAR
    # ======================
    elif cmd.startswith("py "):
        self.run_python(cmd[3:])

    elif cmd.startswith("makepy "):
        self.create_python_file(cmd[7:])

    elif cmd.startswith("analyze "):
        self.analyze_code(cmd[8:])

    # ======================
    # INTERNET
    # ======================
    elif cmd.startswith("google "):
        self.google_search(cmd[7:])

    elif cmd.startswith("youtube "):
        self.youtube_search(cmd[8:])

    elif cmd.startswith("github "):
        self.github_search(cmd[7:])

    elif cmd.startswith("download "):
        self.download_file(cmd[9:])

    # ======================
    # CMD BUYRUQLAR
    # ======================
    elif cmd.startswith("cmd "):
        self.run_cmd(cmd[4:])

    elif cmd == "cmd":
        self.open_cmd()

    elif cmd == "powershell":
        self.open_powershell()

    elif cmd == "notepad":
        self.open_notepad()

    elif cmd == "calc":
        self.open_calculator()

    elif cmd == "paint":
        self.open_paint()

    elif cmd == "taskmgr":
        self.open_task_manager()

    # ======================
    # AI
    # ======================
    elif cmd.startswith("ai "):
        result = self.ai_chat(cmd[3:])
        self.speak(result)

    # ======================
    # TELEGRAM BOT
    # ======================
    elif cmd.startswith("bot "):
        self.create_telegram_bot(cmd[4:])

    # ======================
    # PLUGINS
    # ======================
    elif cmd == "plugins":
        self.list_plugins()

    elif cmd.startswith("plugin "):
        self.create_plugin(cmd[7:])

    # ======================
    # UPDATE
    # ======================
    elif cmd == "update":
        self.check_update()

    # ======================
    # NOTES & TASKS
    # ======================
    elif cmd.startswith("note "):
        self.add_note(cmd[5:])

    elif cmd == "notes":
        self.show_notes()

    elif cmd.startswith("task "):
        self.add_task(cmd[5:])

    elif cmd == "tasks":
        self.show_tasks()

    elif cmd.startswith("done "):
        self.done_task(int(cmd[5:]))

    # ======================
    # GUI
    # ======================
    elif cmd == "gui":
        self.start_gui()

    # ======================
    # EXIT
    # ======================
    elif cmd == "exit":
        self.running = False
        self.speak("Dastur to'xtadi.")

    else:
        self.speak("Buyruq topilmadi.")
