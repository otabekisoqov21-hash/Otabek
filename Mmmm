def add_note(self, text):

    if not text:
        self.speak("Eslatma matni yo'q.")
        return

    self.data["notes"].append({
        "text": text,
        "time": str(datetime.datetime.now())
    })

    self.save_data()

    self.speak("Eslatma qo'shildi.")


def show_notes(self):

    notes = self.data.get("notes", [])

    if not notes:
        self.speak("Eslatmalar yo'q.")
        return

    print("\n===== ESALTMALAR =====")

    for i, n in enumerate(notes, 1):
        print(f"{i}. {n['text']} ({n['time']})")


def delete_note(self, index):

    try:

        self.data["notes"].pop(index - 1)

        self.save_data()

        self.speak("Eslatma o'chirildi.")

    except:

        self.speak("Xato index.")


def add_task(self, task):

    if not task:
        self.speak("Vazifa yo'q.")
        return

    self.data["tasks"].append({
        "task": task,
        "done": False,
        "time": str(datetime.datetime.now())
    })

    self.save_data()

    self.speak("Vazifa qo'shildi.")


def show_tasks(self):

    tasks = self.data.get("tasks", [])

    if not tasks:
        self.speak("Vazifalar yo'q.")
        return

    print("\n===== VAZIFALAR =====")

    for i, t in enumerate(tasks, 1):

        status = "✔" if t["done"] else "✖"

        print(f"{i}. {t['task']} [{status}]")


def done_task(self, index):

    try:

        self.data["tasks"][index - 1]["done"] = True

        self.save_data()

        self.speak("Vazifa bajarildi.")

    except:

        self.speak("Xato index.")


def delete_task(self, index):

    try:

        self.data["tasks"].pop(index - 1)

        self.save_data()

        self.speak("Vazifa o'chirildi.")

    except:

        self.speak("Xato index.")


def clear_all(self):

    self.data["notes"] = []
    self.data["tasks"] = []

    self.save_data()

    self.speak("Hammasi tozalandi.")


def reminder_loop(self):

    while True:

        time.sleep(10)

        if self.data["tasks"]:

            for t in self.data["tasks"]:

                if not t["done"]:

                    print("⏰ Eslatma:", t["task"])
