def create_telegram_bot(self, bot_name):

    if not bot_name:
        bot_name = "MyBot"

    folder = os.path.join(self.workspace, bot_name)

    os.makedirs(folder, exist_ok=True)

    main_code = '''from telegram import Update
from telegram.ext import (
ApplicationBuilder,
CommandHandler,
MessageHandler,
ContextTypes,
filters
)

TOKEN="YOUR_BOT_TOKEN"

async def start(update:Update,
context:ContextTypes.DEFAULT_TYPE):

    await update.message.reply_text(
        "Assalomu alaykum!"
    )

async def help(update:Update,
context:ContextTypes.DEFAULT_TYPE):

    await update.message.reply_text(
        "Yordam menyusi"
    )

async def echo(update:Update,
context:ContextTypes.DEFAULT_TYPE):

    await update.message.reply_text(
        update.message.text
    )

app=ApplicationBuilder().token(TOKEN).build()

app.add_handler(CommandHandler("start",start))
app.add_handler(CommandHandler("help",help))
app.add_handler(
MessageHandler(
filters.TEXT & ~filters.COMMAND,
echo
)
)

app.run_polling()
'''

    with open(
        os.path.join(folder, "main.py"),
        "w",
        encoding="utf-8"
    ) as f:
        f.write(main_code)

    with open(
        os.path.join(folder, "requirements.txt"),
        "w",
        encoding="utf-8"
    ) as f:
        f.write("python-telegram-bot==20.7\n")

    with open(
        os.path.join(folder, "README.md"),
        "w",
        encoding="utf-8"
    ) as f:
        f.write("# Telegram Bot\n\n")
        f.write("1. requirements.txt ni o'rnating\n")
        f.write("2. TOKEN ni almashtiring\n")
        f.write("3. python main.py ni ishga tushiring\n")

    self.speak("Telegram bot yaratildi.")


def install_bot_packages(self):

