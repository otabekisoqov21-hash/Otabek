        height=25
    )

    self.output.pack(pady=10)

    self.entry = tk.Entry(
        self.root,
        width=70,
        font=("Arial",12)
    )

    self.entry.pack(pady=5)

    self.entry.bind("<Return>", self.gui_command)

    tk.Button(
        self.root,
        text="Yuborish",
        command=self.gui_send,
        width=15
    ).pack(pady=5)

    tk.Button(
        self.root,
        text="System Info",
        command=self.gui_system,
        width=15
    ).pack()

    tk.Button(
        self.root,
        text="Workspace",
        command=self.open_workspace,
        width=15
    ).pack()

    self.output.insert(
        tk.END,
        "JARVIS AI 10.0 Professional ishga tushdi.\n"
    )

    self.root.mainloop()


def gui_send(self):

    cmd = self.entry.get()

    self.output.insert(
        tk.END,
        "\nSiz : " + cmd + "\n"
    )

    self.entry.delete(0, tk.END)

    self.execute_gui(cmd)


def gui_command(self, event):

    self.gui_send()


def execute_gui(self, cmd):

    cmd = cmd.lower()

    if cmd == "system":

        ram = psutil.virtual_memory()

        self.output.insert(
            tk.END,
            f"RAM: {ram.percent}%\n"
        )

    elif cmd == "files":

        files = os.listdir(self.workspace)

        for f in files:

            self.output.insert(
                tk.END,
                f + "\n"
            )

    elif cmd == "time":

        self.output.insert(
            tk.END,
            str(datetime.datetime.now()) + "\n"
        )

    elif cmd.startswith("google "):

        self.google_search(cmd[7:])

        self.output.insert(
            tk.END,
            "Google ochildi\n"
        )

    else:

        self.output.insert(
            tk.END,
            "Buyruq topilmadi.\n"
        )


