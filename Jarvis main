def check_update(self):

    try:

        url = "https://example.com/jarvis/version.txt"

        r = requests.get(url, timeout=10)

        latest_version = r.text.strip()

        current_version = self.version

        print("Current:", current_version)
        print("Latest :", latest_version)

        if latest_version != current_version:

            self.speak("Yangi versiya topildi.")

            return latest_version

        else:

            self.speak("Sizda eng so'nggi versiya bor.")

            return None

    except Exception as e:

        print(e)

        self.speak("Yangilanish tekshirib bo'lmadi.")

        return None


def download_update(self, url):

    try:

        file_name = "jarvis_update.py"

        path = os.path.join(self.workspace, file_name)

        r = requests.get(url, stream=True, timeout=30)

        with open(path, "wb") as f:

            for chunk in r.iter_content(8192):

                if chunk:
                    f.write(chunk)

        self.speak("Yangilanish yuklab olindi.")

        return path

    except Exception as e:

        print(e)

        self.speak("Yuklab olishda xato.")

        return None


def apply_update(self, file_path):

    try:

        if os.path.exists(file_path):

            backup = self.workspace + "/backup.py"

            shutil.copy2(__file__, backup)

            shutil.copy2(file_path, __file__)

            self.speak("Yangilanish o'rnatildi. Qayta ishga tushiring.")

        else:

            self.speak("Fayl topilmadi.")

    except Exception as e:

        print(e)

        self.speak("Yangilashda xato.")


def rollback_update(self):

    try:

        backup = self.workspace + "/backup.py"

        if os.path.exists(backup):

            shutil.copy2(backup, __file__)

            self.speak("Oldingi versiya tiklandi.")

