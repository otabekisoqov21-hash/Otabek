# ==========================
class VoiceEngine:

    def __init__(self):
        self.voice = "uz-UZ-SardorNeural"  # Uzbek ovoz (agar ishlamasa default bo'ladi)

    async def _speak_async(self, text, file="voice.mp3"):

        communicate = edge_tts.Communicate(text, self.voice)

        await communicate.save(file)

        try:
            if platform.system() == "Windows":
                os.system(f"start {file}")
            else:
                os.system(f"mpg123 {file}")
        except:
            pass

    def speak(self, text):

        print("[JARVIS]:", text)

        try:
            asyncio.run(self._speak_async(text))
        except Exception as e:
            print("TTS error:", e)


