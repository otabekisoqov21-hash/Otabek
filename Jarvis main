        print("OS:", platform.system())
        print("Python:", platform.python_version())

    # ======================
    # 🧠 AI SIMPLE
    # ======================
    def ai(self, text):

        if "salom" in text:
            return "Salom! Men JARVISman."

        elif "isming" in text:
            return "Mening ismim JARVIS 10.0"

        elif "vaqt" in text:
            return str(datetime.datetime.now())

        else:
            return "Tushunmadim"

    # ======================
    # ⚙️ EXECUTE ENGINE
    # ======================
    def execute(self, cmd):

        if cmd == "exit":
            self.running = False

        elif cmd == "files":
            self.list_files()

        elif cmd.startswith("mk "):
            self.create_file(cmd[3:])

        elif cmd.startswith("read "):
            self.read_file(cmd[5:])

        elif cmd.startswith("google "):
            self.google(cmd[7:])

        elif cmd == "system":
            self.system_info()

        elif cmd.startswith("ai "):
            self.speak(self.ai(cmd[3:]))

        else:
            self.speak("Buyruq topilmadi")


